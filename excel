/***************
 * GET (data API)
 ***************/
function doGet(e) {
  try {
    const action = e?.parameter?.action ? String(e.parameter.action) : "all";
    const callback = e?.parameter?.callback ? String(e.parameter.callback) : null;
    if (action === "ping") {
      return output_({ ok: true, action: "ping", ts: new Date().toISOString() }, callback);
    }
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

    let payload;
    if (action === "all") {
      const inspectors = readSheetAsObjects_(ss, SHEET_NAMES.inspectors);
      payload = {
        sections: readSheetAsObjects_(ss, SHEET_NAMES.sections),
        checklist: readSheetAsObjects_(ss, SHEET_NAMES.checklist),
        branches: readSheetAsObjects_(ss, SHEET_NAMES.branches),
        roll_weights: readSheetAsObjects_(ss, SHEET_NAMES.roll_weights),
        inspectors: stripSensitiveInspectorFields_(inspectors),
        settings: SETTINGS,
        meta: { updatedAt: new Date().toISOString() },
      };
    } else if (action === "sections") payload = readSheetAsObjects_(ss, SHEET_NAMES.sections);
    else if (action === "checklist") payload = readSheetAsObjects_(ss, SHEET_NAMES.checklist);
    else if (action === "branches") payload = readSheetAsObjects_(ss, SHEET_NAMES.branches);
    else if (action === "settings") payload = SETTINGS;
    else if (action === "my_submissions") {
      const tgUserId = e?.parameter?.tg_user_id ? String(e.parameter.tg_user_id).trim() : "";
      const limitRaw = e?.parameter?.limit ? String(e.parameter.limit).trim() : "";
      payload = getMySubmissionsPayload_(ss, tgUserId, limitRaw);
    }
    else if (action === "telegram_login") {
      const loginData = {};
      const fields = ["id", "first_name", "last_name", "username", "photo_url", "auth_date", "hash"];
      fields.forEach((key) => {
        const value = e?.parameter?.[key];
        if (value !== undefined && value !== null && String(value).trim() !== "") {
          loginData[key] = String(value);
        }
      });
      const verified = verifyTelegramLogin_(loginData, TELEGRAM_BOT_TOKEN);
      payload = verified
        ? { ok: true, user: verified }
        : { ok: false, error: "telegram_login_invalid" };
    }
    else if (action === "browser_auth") {
      const fio = e?.parameter?.fio ? String(e.parameter.fio).trim() : "";
      const code = e?.parameter?.code ? String(e.parameter.code).trim() : "";
      payload = verifyBrowserAuth_(ss, fio, code);
    }
    else if (action === "load_draft") {
      const draftId = e?.parameter?.draft_id ? String(e.parameter.draft_id).trim() : "";
      payload = loadDraftPayload_(ss, draftId);
    }
    else if (action === "create_continue_token") {
      const draftId = e?.parameter?.draft_id ? String(e.parameter.draft_id).trim() : "";
      const createdFrom = e?.parameter?.created_from ? String(e.parameter.created_from).trim() : "";
      payload = createContinueToken_(ss, draftId, createdFrom);
    }
    else if (action === "resolve_continue_token") {
      const token = e?.parameter?.token ? String(e.parameter.token).trim() : "";
      payload = resolveContinueToken_(ss, token);
    }
    else if (action === "submission") {
      const submissionId = e?.parameter?.submission_id ? String(e.parameter.submission_id).trim() : "";
      payload = getSubmissionPayload_(ss, submissionId);
    }
    else payload = { error: "Unknown action", action };

    return output_(payload, callback);
  } catch (err) {
    return output_(
      { error: String(err), stack: err?.stack ?? null },
      e?.parameter?.callback ?? null
    );
  }
}

/***************
 * POST (submit answers)
 ***************/
function doPost(e) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  try {
    // Apps Script WebApp обычно кладёт form fields в e.parameter,
    // но на всякий случай поддержим e.postData.contents
    const params = (e && e.parameter) ? e.parameter : {};
    const action = params.action ? String(params.action) : "";

    const raw = extractPayloadFromPost_(e, params);
    if (!raw) throw new Error("Empty payload");

    const payload = JSON.parse(raw);
    logInfo_("doPost: received payload", {
      action,
      partial: !!payload?.partial,
      submission_id: safe_(payload?.submission_id),
      branch_id: safe_(payload?.branch_id),
      branch_name: safe_(payload?.branch_name),
    });

    if (action === "send_message") {
      const sendRes = sendTelegramMessageFromPayload_(ss, payload, { action });
      logInfo_("doPost: send_message result", sendRes);
      return text_("OK");
    }

    if (action === "save_draft") {
      const draftRes = upsertDraft_(ss, payload);
      logInfo_("doPost: save_draft result", draftRes);
      return text_("OK");
    }

    if (action !== "submit") {
      return text_("OK");
    }

    // Обновляем/добавляем проверяющего
    try {
      upsertInspector_(ss, payload);
    } catch (inspectorErr) {
      logError_("doPost: upsertInspector failed", inspectorErr);
    }

    // Ensure output sheets exist & have headers
    const shSub = getOrCreateSheet_(ss, SHEET_NAMES.submissions, SUBMISSIONS_HEADERS);
    const shAns = getOrCreateSheet_(ss, SHEET_NAMES.answers, ANSWERS_HEADERS);

    // Prepare answers rows (flat)
    const flatRaw = Array.isArray(payload.answers_rows)
      ? payload.answers_rows
      : (Array.isArray(payload.answers_flat) ? payload.answers_flat : []);
    const flat = mergeDraftPhotosIntoAnswerRows_(ss, payload, flatRaw);
    const deduped = reuseExistingUploadedAnswerPhotos_(shAns, payload, flat);

    const shouldUploadInline = shouldUploadPhotosInline_(payload);
    const driveUpload = shouldUploadInline
      ? uploadAnswerPhotosToDrive_(ss, payload, deduped.rows)
      : buildDeferredDriveUploadMeta_(deduped.rows, "inline_upload_disabled");
    if (deduped.reused > 0) {
      driveUpload.meta = {
        ...(driveUpload.meta || {}),
        reused_existing_photos: deduped.reused,
      };
    }
    const effectiveFlat = driveUpload.flat;
    logInfo_("doPost: drive upload meta", driveUpload.meta);

    // Prepare values (one submission row)
    const tg = payload.tg || {};
    const meta = payload.meta || {};
    const metaJson = mergeMetaJsonWith_(payload.meta_json, {
      drive_upload: driveUpload.meta,
      saved_payload: buildSavedSubmissionPayload_(payload, effectiveFlat),
    });
    const tgUserId = safe_(payload.tg_user_id || payload.tg_id || tg.user_id || tg.id);

    const subRow = [
      safe_(payload.submission_id),
      safe_(payload.submitted_at),
      safe_(payload.fio),
      safe_(payload.city),
      safe_(payload.branch_id),
      safe_(payload.branch_name),
      safe_(payload.zone),
      safe_(payload.inspection_area),
      safe_(payload.percent),
      safe_(payload.earned),
      safe_(payload.max_score),
      tgUserId,
      metaJson || json_(meta),
    ];

    shSub.appendRow(subRow);

    if (effectiveFlat.length) {
      const rows = effectiveFlat.map(a => ({
        submission_id: safe_(payload.submission_id),
        submitted_at: safe_(payload.submitted_at),
        fio: safe_(payload.fio),
        city: safe_(payload.city),
        branch_id: safe_(payload.branch_id),
        branch_name: safe_(payload.branch_name),
        section_code: safe_(a.section_code || a.section_id || ""),
        section_title: safe_(a.section_title),
        question_id: safe_(a.question_id),
        critikal: safe_(a.critikal || (String(a.severity || "").toLowerCase() === "critical" ? "critical" : "")),
        question_text: safe_(a.question_text),
        severity: safe_(a.severity),
        answer_key: safe_(a.answer_key || a.answer_value),
        answer_text: safe_(a.answer_text || a.answer_label),
        score_earned: safe_(a.score_earned),
        score_max: safe_(a.score_max),
        comment: safe_(a.comment),
        photos_json: json_(a.photos),
      }));

      appendObjectsRowsByHeaders_(shAns, rows);
    }

    const shouldSendTelegram = !payload.partial && !payload.skip_telegram;
    const tgSendRes = shouldSendTelegram
      ? sendTelegramMessageFromPayload_(ss, payload, { action })
      : { ok: false, info: "skip_partial" };
    logInfo_("doPost: telegram send result", tgSendRes);

    if (safe_(payload?.draft_id) && !payload?.partial) {
      markDraftSubmitted_(ss, safe_(payload.draft_id));
    }

    return text_("OK");

  } catch (err) {
    logError_("doPost: failed", err);
    // Всё равно отдаём OK, чтобы iframe не ломал UX
    return text_("OK");
  }
}

/***************
 * Helpers
 ***************/
function output_(data, callback) {
  const json = JSON.stringify(data);

  // JSONP (обходит CORS)
  if (callback) {
    return ContentService
      .createTextOutput(`${callback}(${json});`)
      .setMimeType(ContentService.MimeType.JAVASCRIPT);
  }

  // обычный JSON
  return ContentService
    .createTextOutput(json)
    .setMimeType(ContentService.MimeType.JSON);
}

function text_(s) {
  return ContentService
    .createTextOutput(String(s))
    .setMimeType(ContentService.MimeType.TEXT);
}

function readSheetAsObjects_(ss, name) {
  const sh = ss.getSheetByName(name);
  if (!sh) return [];
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return [];
  const headers = values[0].map(h => String(h).trim());

  return values.slice(1)
    .filter(r => r.some(cell => String(cell).trim() !== ""))
    .map(r => {
      const obj = {};
      headers.forEach((h, i) => obj[h] = r[i]);
      return obj;
    });
}

function readSheetAsKeyValue_(ss, name) {
  const sh = ss.getSheetByName(name);
  if (!sh) return {};
  const values = sh.getDataRange().getValues();
  const out = {};
  for (let i = 1; i < values.length; i++) {
    const key = String(values[i][0] ?? "").trim();
    if (key) out[key] = values[i][1];
  }
  return out;
}

function inspectorCodeAliases_() {
  return [
    "access_code", "auth_code", "browser_code", "login_code", "code",
    "код", "код_доступа", "код доступа"
  ];
}

function normalizeAccessCode_(code) {
  return String(code || "").trim().replace(/\s+/g, "").toLowerCase();
}

function normalizeFioForCompare_(fio) {
  return String(fio || "").trim().replace(/\s+/g, " ").toLowerCase();
}

function stripSensitiveInspectorFields_(rows) {
  const sensitive = inspectorCodeAliases_().map(normalizeHeaderKey_);
  return (rows || []).map(row => {
    const out = {};
    Object.keys(row || {}).forEach(key => {
      if (!sensitive.includes(normalizeHeaderKey_(key))) out[key] = row[key];
    });
    return out;
  });
}

function verifyBrowserAuth_(ss, fio, code) {
  const cleanFio = String(fio || "").trim().replace(/\s+/g, " ");
  const cleanCode = normalizeAccessCode_(code);
  if (!cleanFio) return { ok: false, error: "fio_required" };

  const inspectors = readSheetAsObjects_(ss, SHEET_NAMES.inspectors);
  const fioKey = normalizeFioForCompare_(cleanFio);
  const rowByFio = (inspectors || []).find(item => {
    const rowName = getByKeys_(item, ["fio", "name", "tg_name", "ФИО", "фио", "проверяющий"]);
    return normalizeFioForCompare_(rowName) === fioKey;
  }) || null;

  if (!cleanCode) {
    const rowCode = rowByFio ? getByKeys_(rowByFio, inspectorCodeAliases_()) : "";
    if (normalizeAccessCode_(rowCode)) {
      return { ok: false, error: "code_required_for_fio" };
    }

    const rowId = rowByFio ? String(getByKeys_(rowByFio, ["tg_user_id", "tg_id", "id"]) || "").trim() : "";
    const id = rowId || `browser_${fioKey.replace(/[^a-zа-я0-9]+/gi, "_") || Date.now()}`;
    return {
      ok: true,
      user: {
        id,
        username: "",
        first_name: "",
        last_name: "",
        name: cleanFio,
        browser_auth: true,
        is_uk_checker: false,
        mc_or_no: "",
      },
    };
  }

  const rowByCode = (inspectors || []).find(item => {
    const rowCode = getByKeys_(item, inspectorCodeAliases_());
    return normalizeAccessCode_(rowCode) === cleanCode;
  }) || null;

  if (!rowByCode) return { ok: false, error: "code_not_found" };

  if (rowByFio && rowByCode !== rowByFio) {
    return { ok: false, error: "code_fio_mismatch" };
  }

  const rowId = String(getByKeys_(rowByCode, ["tg_user_id", "tg_id", "id"]) || "").trim();
  const rowName = String(getByKeys_(rowByCode, ["fio", "name", "tg_name", "ФИО", "фио", "проверяющий"]) || "").trim();
  const id = rowId || `code_${cleanCode}`;

  return {
    ok: true,
    user: {
      id,
      username: "",
      first_name: "",
      last_name: "",
      name: cleanFio || rowName,
      browser_auth: true,
      is_uk_checker: true,
      mc_or_no: "ук",
    },
  };
}

function addHours_(date, hours) {
  return new Date((date || new Date()).getTime() + Number(hours || 0) * 60 * 60 * 1000);
}

function makeRandomId_(prefix) {
  const bytes = Utilities.getUuid().replace(/-/g, "") + Utilities.getUuid().replace(/-/g, "");
  return `${prefix || "id"}_${bytes.slice(0, 48)}`;
}

function upsertDraft_(ss, payload) {
  const draftId = safe_(payload?.draft_id);
  if (!draftId) return { ok: false, error: "draft_id_required" };

  const sh = getOrCreateSheet_(ss, SHEET_NAMES.drafts, DRAFTS_HEADERS);
  const now = new Date();
  const nowIso = now.toISOString();
  const expiresAt = safe_(payload?.expires_at) || addHours_(now, DRAFT_TTL_HOURS).toISOString();
  const tg = payload?.tg || {};
  const ownerTgId = safe_(payload?.owner_tg_user_id || payload?.tg_user_id || payload?.tg_id || tg.user_id || tg.id);
  const ownerBrowserId = safe_(payload?.owner_browser_id || payload?.browser_id || "");
  const ownerName = safe_(payload?.owner_name || payload?.fio || payload?.tg_name || tg.name || "");
  const ownerMode = safe_(payload?.owner_mode || (ownerTgId ? "telegram" : (ownerBrowserId ? "browser" : "unknown")));
  const draftPayload = normalizeDraftPhotosForStorage_(ss, payload, payload?.payload || parseJsonObject_(payload?.payload_json));
  const payloadJson = json_(draftPayload || {});

  const record = {
    draft_id: draftId,
    updated_at: nowIso,
    expires_at: expiresAt,
    status: safe_(payload?.status || "draft"),
    owner_mode: ownerMode,
    owner_tg_user_id: ownerTgId,
    owner_browser_id: ownerBrowserId,
    owner_name: ownerName,
    branch_id: safe_(payload?.branch_id),
    branch_name: safe_(payload?.branch_name),
    payload_json: payloadJson,
  };

  const rowIndex = findSheetRowIndexByValue_(sh, "draft_id", draftId);
  if (!rowIndex) {
    appendObjectRowByHeaders_(sh, { ...record, created_at: nowIso });
  } else {
    updateObjectRowByHeaders_(sh, rowIndex, record);
  }

  return { ok: true, draft_id: draftId, updated_at: nowIso, expires_at: expiresAt };
}

function loadDraftPayload_(ss, draftId) {
  const id = safe_(draftId);
  if (!id) return { ok: false, error: "draft_id_required" };

  const sh = getOrCreateSheet_(ss, SHEET_NAMES.drafts, DRAFTS_HEADERS);
  const row = findRowById_(sh, "draft_id", id);
  if (!row) return { ok: false, error: "draft_not_found", draft_id: id };

  const status = safe_(row.status || "draft");
  if (status === "submitted") return { ok: false, error: "draft_submitted", draft_id: id };

  const expiresAt = row.expires_at ? new Date(row.expires_at) : null;
  if (expiresAt && Number.isFinite(expiresAt.getTime()) && expiresAt.getTime() < Date.now()) {
    return { ok: false, error: "draft_expired", draft_id: id, expires_at: row.expires_at };
  }

  return {
    ok: true,
    draft_id: id,
    status,
    updated_at: row.updated_at || "",
    expires_at: row.expires_at || "",
    payload: parseJsonObject_(row.payload_json),
  };
}

function createContinueToken_(ss, draftId, createdFrom) {
  const id = safe_(draftId);
  if (!id) return { ok: false, error: "draft_id_required" };

  const draft = loadDraftPayload_(ss, id);
  if (!draft.ok) return draft;

  const sh = getOrCreateSheet_(ss, SHEET_NAMES.continue_tokens, CONTINUE_TOKENS_HEADERS);
  const now = new Date();
  const expiresAt = addHours_(now, CONTINUE_TOKEN_TTL_HOURS).toISOString();
  const token = makeRandomId_("ct");
  appendObjectRowByHeaders_(sh, {
    continue_token: token,
    draft_id: id,
    created_at: now.toISOString(),
    expires_at: expiresAt,
    used_at: "",
    created_from: safe_(createdFrom || ""),
  });

  return {
    ok: true,
    continue_token: token,
    draft_id: id,
    expires_at: expiresAt,
    ttl_hours: CONTINUE_TOKEN_TTL_HOURS,
  };
}

function resolveContinueToken_(ss, token) {
  const cleanToken = safe_(token);
  if (!cleanToken) return { ok: false, error: "continue_token_required" };

  const sh = getOrCreateSheet_(ss, SHEET_NAMES.continue_tokens, CONTINUE_TOKENS_HEADERS);
  const rowIndex = findSheetRowIndexByValue_(sh, "continue_token", cleanToken);
  if (!rowIndex) return { ok: false, error: "continue_token_not_found" };

  const row = getObjectRowByIndex_(sh, rowIndex);
  const expiresAt = row.expires_at ? new Date(row.expires_at) : null;
  if (expiresAt && Number.isFinite(expiresAt.getTime()) && expiresAt.getTime() < Date.now()) {
    return { ok: false, error: "continue_token_expired", expires_at: row.expires_at };
  }

  const headerMap = getHeaderMap_(sh);
  if (headerMap.used_at) sh.getRange(rowIndex, headerMap.used_at).setValue(new Date().toISOString());

  const draft = loadDraftPayload_(ss, safe_(row.draft_id));
  if (!draft.ok) return draft;
  return {
    ...draft,
    continue_token: cleanToken,
    token_expires_at: row.expires_at || "",
  };
}

function markDraftSubmitted_(ss, draftId) {
  const id = safe_(draftId);
  if (!id) return { ok: false, error: "draft_id_required" };
  const sh = getOrCreateSheet_(ss, SHEET_NAMES.drafts, DRAFTS_HEADERS);
  const rowIndex = findSheetRowIndexByValue_(sh, "draft_id", id);
  if (!rowIndex) return { ok: false, error: "draft_not_found" };
  updateObjectRowByHeaders_(sh, rowIndex, {
    updated_at: new Date().toISOString(),
    status: "submitted",
  });
  return { ok: true, draft_id: id, status: "submitted" };
}

function mergeDraftPhotosIntoAnswerRows_(ss, payload, flatRows) {
  const rows = Array.isArray(flatRows) ? flatRows : [];
  const draftId = safe_(payload?.draft_id);
  if (!draftId || !rows.length) return rows;

  const sh = ss.getSheetByName(SHEET_NAMES.drafts);
  if (!sh) return rows;

  const draftRow = findRowById_(sh, "draft_id", draftId);
  if (!draftRow) return rows;

  const draftPayload = parseJsonObject_(draftRow.payload_json);
  const notes = draftPayload?.issueNotes || {};
  if (!notes || typeof notes !== "object") return rows;

  let mergedCount = 0;
  const out = rows.map(row => {
    const qid = safe_(row?.question_id);
    if (!qid || !notes[qid]) return row;

    const draftPhotos = normalizePhotosList_(notes[qid]?.photos);
    if (!draftPhotos.length) return row;

    const hasStoredDraftPhotos = draftPhotos.some(photo => !isDataUrlImage_(photo));
    const rowPhotos = normalizePhotosList_(row?.photos)
      .filter(photo => !(hasStoredDraftPhotos && isDataUrlImage_(photo)));

    const seen = new Set(rowPhotos.map(photoIdentityKey_));
    const mergedPhotos = [...rowPhotos];
    draftPhotos.forEach(photo => {
      const src = String(photo || "").trim();
      const key = photoIdentityKey_(src);
      if (!src || seen.has(key)) return;
      seen.add(key);
      mergedPhotos.push(src);
      mergedCount += 1;
    });

    return {
      ...row,
      photos: mergedPhotos,
    };
  });

  if (mergedCount > 0) {
    logInfo_("mergeDraftPhotosIntoAnswerRows: merged draft photos", {
      draft_id: draftId,
      merged: mergedCount,
    });
  }
  return out;
}

function buildSavedSubmissionPayload_(payload, effectiveFlat) {
  if (payload?.partial) return null;

  const rows = (Array.isArray(effectiveFlat) ? effectiveFlat : []).map(row => ({
    ...row,
    photos_json: json_(row?.photos || []),
  }));
  const normalizedRows = normalizeAnswersRows_(rows);
  const rowIssues = buildIssuesFromAnswerRows_(normalizedRows);

  return {
    submission_id: safe_(payload?.submission_id),
    zone: safe_(payload?.zone),
    percent: payload?.percent ?? "",
    city: safe_(payload?.city),
    branch_id: safe_(payload?.branch_id),
    branch_name: safe_(payload?.branch_name),
    fio: safe_(payload?.fio),
    submitted_at: safe_(payload?.submitted_at),
    answers: payload?.answers || {},
    issues: rowIssues.length ? rowIssues : (Array.isArray(payload?.issues) ? payload.issues : []),
  };
}

function getObjectAny_(obj, aliases) {
  if (!obj) return "";
  const keys = Object.keys(obj);
  const direct = aliases.find(key => obj[key] !== undefined && obj[key] !== null && String(obj[key]).trim() !== "");
  if (direct) return obj[direct];

  const normalizedAliases = aliases.map(normalizeHeaderKey_);
  for (let i = 0; i < keys.length; i += 1) {
    const key = keys[i];
    if (normalizedAliases.includes(normalizeHeaderKey_(key))) {
      const value = obj[key];
      if (value !== undefined && value !== null && String(value).trim() !== "") return value;
    }
  }
  return "";
}

function buildQuestionSectionMap_(ss) {
  const sections = readSheetAsObjects_(ss, SHEET_NAMES.sections);
  const sectionTitleByCode = {};
  (sections || []).forEach(section => {
    const code = safe_(getObjectAny_(section, ["section_code", "section_id", "code", "id", "код", "код_раздела"]));
    const title = safe_(getObjectAny_(section, ["title", "section_title", "name", "название", "раздел"]));
    if (code) sectionTitleByCode[code] = title || code;
  });

  const map = {};
  const questions = readSheetAsObjects_(ss, SHEET_NAMES.checklist);
  (questions || []).forEach(question => {
    const qid = safe_(getObjectAny_(question, ["question_id", "id", "questionId", "qid", "ID вопроса"]));
    if (!qid || /^id\s*вопроса$/i.test(qid) || qid === "question_id") return;

    const sectionCode = safe_(getObjectAny_(question, ["section_code", "section_id", "section", "раздел"]));
    const sectionTitle = safe_(getObjectAny_(question, ["section_title", "section_name", "название_раздела"]));
    map[qid] = {
      section_code: sectionCode,
      section_title: sectionTitle || sectionTitleByCode[sectionCode] || sectionCode || "Общая",
    };
  });
  return map;
}

function normalizeDraftPhotosForStorage_(ss, payload, draftPayload) {
  const draft = draftPayload && typeof draftPayload === "object" ? draftPayload : {};
  const notes = draft.issueNotes || {};
  const rows = [];
  const keys = [];
  const questionSectionMap = buildQuestionSectionMap_(ss);

  Object.keys(notes || {}).forEach((key, idx) => {
    const photos = normalizePhotosList_(notes[key]?.photos);
    if (!photos.some(isDataUrlImage_)) return;
    const sectionMeta = questionSectionMap[key] || {};
    rows.push({
      section_title: sectionMeta.section_title || "Черновик",
      section_code: sectionMeta.section_code || "draft",
      question_id: key || `note_${idx + 1}`,
      photos,
    });
    keys.push(key);
  });

  if (!rows.length) return draft;

  const upload = uploadAnswerPhotosToDrive_(ss, {
    submission_id: safe_(payload?.draft_id || draft.draftId || "draft"),
    branch_id: safe_(payload?.branch_id || draft.branchId),
    branch_name: safe_(payload?.branch_name || ""),
  }, rows);

  if (!upload || !upload.flat || !upload.meta || upload.meta.ok === false) return draft;

  const nextNotes = { ...notes };
  upload.flat.forEach((row, idx) => {
    const key = keys[idx];
    if (!key || !nextNotes[key]) return;
    nextNotes[key] = {
      ...nextNotes[key],
      photos: normalizePhotosList_(row.photos),
    };
  });

  return {
    ...draft,
    issueNotes: nextNotes,
  };
}

function getOrCreateSheet_(ss, name, headers) {
  let sh = ss.getSheetByName(name);
  if (!sh) sh = ss.insertSheet(name);

  // Ensure header row exists and correct
  const lastCol = Math.max(sh.getLastColumn(), headers.length);
  const existing = sh.getRange(1, 1, 1, lastCol).getValues()[0].map(v => String(v || "").trim());

  const needRewrite =
    existing.slice(0, headers.length).join("|") !== headers.join("|");

  if (needRewrite) {
    sh.getRange(1, 1, 1, headers.length).setValues([headers]);
    sh.setFrozenRows(1);
  }

  return sh;
}



function processPendingAnswerPhotos_(limit) {
  const maxRows = Number(limit) > 0 ? Number(limit) : 50;
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const shAns = ss.getSheetByName(SHEET_NAMES.answers);
  if (!shAns) return { ok: false, status: "answers_sheet_missing", processed: 0, uploaded: 0, failed: 0 };

  const range = shAns.getDataRange();
  const values = range.getValues();
  if (!values || values.length < 2) return { ok: true, status: "empty", processed: 0, uploaded: 0, failed: 0 };

  const headers = values[0].map(h => String(h || "").trim());
  const idx = {};
  headers.forEach((h, i) => { idx[h] = i; });

  const need = ["submission_id", "branch_id", "branch_name", "section_title", "photos_json"];
  if (need.some(k => idx[k] === undefined)) {
    return { ok: false, status: "headers_missing", reason: "Required headers not found", processed: 0, uploaded: 0, failed: 0 };
  }

  let processed = 0;
  let uploaded = 0;
  let failed = 0;

  for (let r = 1; r < values.length; r += 1) {
    if (processed >= maxRows) break;

    const photosCell = values[r][idx.photos_json];
    const photos = normalizePhotosList_(photosCell);
    if (!photos.some(isDataUrlImage_)) continue;

    processed += 1;
    const payload = {
      submission_id: safe_(values[r][idx.submission_id]),
      branch_id: safe_(values[r][idx.branch_id]),
      branch_name: safe_(values[r][idx.branch_name]),
    };

    const row = {
      section_title: safe_(values[r][idx.section_title]),
      photos,
    };

    const res = uploadAnswerPhotosToDrive_(ss, payload, [row]);
    if (!res.meta || !res.meta.ok) {
      failed += 1;
      continue;
    }

    const nextPhotos = (res.flat && res.flat[0] && res.flat[0].photos) ? res.flat[0].photos : photos;
    shAns.getRange(r + 1, idx.photos_json + 1).setValue(json_(nextPhotos));
    uploaded += Number(res.meta.uploaded || 0);
  }

  return { ok: failed === 0, status: failed === 0 ? "processed" : "processed_with_errors", processed, uploaded, failed };
}

function safe_(v) {
  if (v === null || v === undefined) return "";
  // Apps Script любит boolean/number норм, оставим как есть
  return v;
}

function normalizeHeaderKey_(value) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .replace(/[\s\-]+/g, "_")
    .replace(/[^a-zа-я0-9_]/g, "")
    .replace(/_+/g, "_")
    .replace(/^_+|_+$/g, "");
}

function json_(v) {
  if (v === null || v === undefined) return "";
  try { return JSON.stringify(v); } catch { return ""; }
}

function parseJsonObject_(value) {
  if (!value) return {};
  if (typeof value === "object") return value;
  try {
    const parsed = JSON.parse(String(value));
    return parsed && typeof parsed === "object" ? parsed : {};
  } catch (_) {
    return {};
  }
}

function mergeMetaJsonWith_(metaJson, extra) {
  const base = parseJsonObject_(metaJson);
  const out = { ...base, ...(extra || {}) };
  return json_(out);
}

function shouldUploadPhotosInline_(payload) {
  const props = PropertiesService.getScriptProperties();
  const modeRaw = String(props.getProperty("PHOTO_UPLOAD_MODE") || "").trim().toLowerCase();
  const mode = modeRaw || "auto";

  if (mode === "inline") return true;
  if (mode === "deferred") return false;

  if (mode === "auto") {
    return !payload?.partial;
  }

  return false;
}

function buildDeferredDriveUploadMeta_(flatRows, reason) {
  return {
    flat: flatRows,
    meta: {
      ok: true,
      status: "deferred",
      uploaded: 0,
      failed: 0,
      total: countPhotosInRows_(flatRows),
      action_required: "Run processPendingAnswerPhotos_ from script owner account (or install a time trigger for it) to upload queued data URL photos.",
      reason: String(reason || "deferred"),
    },
  };
}

function parseFormUrlEncoded_(s) {
  const out = {};
  String(s || "").split("&").forEach(pair => {
    const idx = pair.indexOf("=");
    const k = idx >= 0 ? pair.slice(0, idx) : pair;
    const v = idx >= 0 ? pair.slice(idx + 1) : "";
    if (!k) return;
    out[decodeURIComponent(k)] = decodeURIComponent(String(v || "").replace(/\+/g, " "));
  });
  return out;
}

function extractPayloadFromPost_(e, params) {
  let raw = params && params.payload ? String(params.payload) : "";
  if (!raw && e && e.postData && e.postData.contents) {
    const parsed = parseFormUrlEncoded_(String(e.postData.contents));
    raw = parsed.payload ? String(parsed.payload) : "";
  }
  return raw;
}

function uploadAnswerPhotosToDrive_(ss, payload, flatRows) {
  const rows = Array.isArray(flatRows) ? flatRows : [];

  const resolver = resolveBranchDriveFolder_(ss, payload);
  if (!resolver.ok || !resolver.folder) {
    logInfo_("uploadAnswerPhotosToDrive: branch folder unresolved", resolver);
    return {
      flat: rows,
      meta: {
        ok: false,
        status: resolver.status || "branch_folder_not_found",
        reason: resolver.reason || "",
        uploaded: 0,
        total: countPhotosInRows_(rows),
      },
    };
  }

  const dateFolderName = formatDateFolderNameMsk_(new Date());
  let dateFolder;
  try {
    dateFolder = ensureChildFolderByName_(resolver.folder, dateFolderName);
  } catch (err) {
    logError_("uploadAnswerPhotosToDrive: date folder create/open failed", err);
    return {
      flat: rows,
      meta: {
        ok: false,
        status: "date_folder_access_error",
        reason: String(err || ""),
        uploaded: 0,
        failed: 0,
        total: countPhotosInRows_(rows),
        branch_folder_id: resolver.folder.getId(),
        branch_folder_url: resolver.folder.getUrl(),
        date_folder_name: dateFolderName,
      },
    };
  }

  if (!rows.length) {
    return {
      flat: rows,
      meta: {
        ok: true,
        status: "no_answers_rows",
        uploaded: 0,
        total: 0,
        branch_folder_id: resolver.folder.getId(),
        branch_folder_url: resolver.folder.getUrl(),
        date_folder_id: dateFolder.getId(),
        date_folder_url: dateFolder.getUrl(),
        date_folder_name: dateFolderName,
      },
    };
  }

  let uploaded = 0;
  let failed = 0;
  let total = 0;

  const outRows = rows.map((row, rowIdx) => {
    const photos = normalizePhotosList_(row?.photos);
    if (!photos.length) return row;

    const sectionTitle = safe_(row?.section_title || row?.section || row?.zone_room || "Общая");
    const zoneFolder = ensureChildFolderByName_(dateFolder, sanitizeDriveName_(sectionTitle || "Общая"));

    const nextPhotos = [];
    const seenSources = new Set();
    photos.forEach((photo, photoIdx) => {
      total += 1;
      const src = String(photo || "").trim();
      if (!src) return;
      if (seenSources.has(src)) return;
      seenSources.add(src);

      if (!isDataUrlImage_(src)) {
        if (!nextPhotos.includes(src)) nextPhotos.push(src);
        return;
      }

      try {
        const decoded = decodeImageDataUrl_(src);
        if (!decoded || !decoded.bytes || !decoded.bytes.length) {
          failed += 1;
          return;
        }

        const ext = mimeToFileExt_(decoded.mimeType);
        const fileName = buildUploadedPhotoName_(payload, row, rowIdx, photoIdx, ext, decoded.bytes);
        const existingUrl = findExistingFileUrlByName_(zoneFolder, fileName);
        if (existingUrl) {
          nextPhotos.push(existingUrl);
          return;
        }
        const blob = Utilities.newBlob(decoded.bytes, decoded.mimeType, fileName);
        const file = zoneFolder.createFile(blob);
        nextPhotos.push(file.getUrl());
        uploaded += 1;
      } catch (err) {
        logError_("uploadAnswerPhotosToDrive: photo upload failed", err);
        failed += 1;
      }
    });

    return {
      ...row,
      photos: nextPhotos,
    };
  });

  return {
    flat: outRows,
    meta: {
      ok: failed === 0,
      status: failed === 0 ? "uploaded" : (uploaded > 0 ? "partially_uploaded" : "upload_failed"),
      uploaded,
      failed,
      total,
      branch_folder_id: resolver.folder.getId(),
      branch_folder_url: resolver.folder.getUrl(),
      date_folder_id: dateFolder.getId(),
      date_folder_url: dateFolder.getUrl(),
      date_folder_name: dateFolderName,
    },
  };
}

function countPhotosInRows_(rows) {
  return (rows || []).reduce((acc, row) => acc + normalizePhotosList_(row?.photos).length, 0);
}

function normalizePhotosList_(value) {
  if (Array.isArray(value)) return value.filter(Boolean);
  if (!value) return [];
  if (typeof value === "string") {
    try {
      const parsed = JSON.parse(value);
      if (Array.isArray(parsed)) return parsed.filter(Boolean);
    } catch (_) {}
    return [value];
  }
  return [];
}

function photoIdentityKey_(value) {
  const src = String(value || "").trim();
  if (!src) return "";
  const m1 = src.match(/drive\.google\.com\/file\/d\/([a-zA-Z0-9_-]+)/);
  if (m1 && m1[1]) return `drive:${m1[1]}`;
  const m2 = src.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (m2 && m2[1]) return `drive:${m2[1]}`;
  const m3 = src.match(/googleusercontent\.com\/d\/([a-zA-Z0-9_-]+)/);
  if (m3 && m3[1]) return `drive:${m3[1]}`;
  return src;
}

function reuseExistingUploadedAnswerPhotos_(answersSheet, payload, flatRows) {
  const rows = Array.isArray(flatRows) ? flatRows : [];
  const submissionId = String(payload?.submission_id || "").trim();
  if (!answersSheet || !submissionId || !rows.length) return { rows, reused: 0 };

  const hasInlinePhotos = rows.some(row => normalizePhotosList_(row?.photos).some(isDataUrlImage_));
  if (!hasInlinePhotos) return { rows, reused: 0 };

  const range = answersSheet.getDataRange();
  const values = range.getValues();
  if (!values || values.length < 2) return { rows, reused: 0 };

  const headers = values[0].map(h => String(h || "").trim());
  const idx = {};
  headers.forEach((h, i) => { if (h) idx[h] = i; });

  if (idx.submission_id === undefined || idx.question_id === undefined || idx.photos_json === undefined) {
    return { rows, reused: 0 };
  }

  const existingByQuestion = {};
  for (let r = 1; r < values.length; r += 1) {
    if (String(values[r][idx.submission_id] || "").trim() !== submissionId) continue;

    const photos = normalizePhotosList_(values[r][idx.photos_json]).filter(p => !isDataUrlImage_(p));
    if (!photos.length) continue;

    const key = answerPhotoDedupeKey_({
      section_code: idx.section_code === undefined ? "" : values[r][idx.section_code],
      section_title: idx.section_title === undefined ? "" : values[r][idx.section_title],
      question_id: values[r][idx.question_id],
    });
    if (key && !existingByQuestion[key]) existingByQuestion[key] = photos;
  }

  let reused = 0;
  const nextRows = rows.map(row => {
    const photos = normalizePhotosList_(row?.photos);
    const dataPhotos = photos.filter(isDataUrlImage_);
    if (!dataPhotos.length) return row;

    const key = answerPhotoDedupeKey_(row);
    const existing = key ? existingByQuestion[key] : null;
    if (!existing || !existing.length) return row;

    const nonDataPhotos = photos.filter(p => !isDataUrlImage_(p));
    const remainingDataPhotos = dataPhotos.slice(existing.length);
    reused += Math.min(existing.length, dataPhotos.length);

    return {
      ...row,
      photos: [...existing, ...nonDataPhotos, ...remainingDataPhotos],
    };
  });

  return { rows: nextRows, reused };
}

function answerPhotoDedupeKey_(row) {
  const section = String(row?.section_code || row?.section_id || row?.section_title || "").trim();
  const question = String(row?.question_id || "").trim();
  if (!question) return "";
  return `${section}::${question}`;
}

function resolveBranchDriveFolder_(ss, payload) {
  const directFolder = resolveDirectDriveFolder_(payload);
  if (directFolder && directFolder.ok) return directFolder;

  const branchesSheet = ss.getSheetByName(SHEET_NAMES.branches);
  if (!branchesSheet) {
    return directFolder && !directFolder.ok
      ? directFolder
      : { ok: false, status: "branches_sheet_missing", reason: "Sheet 'Адреса' not found" };
  }

  const found = findBranchRowData_(branchesSheet, payload);
  if (!found) {
    return { ok: false, status: "branch_not_found", reason: "Branch row not found" };
  }

  const folderAliases = [
    "ссылка_на_папку", "ссылка на папку", "папка", "папка_drive", "папка drive", "диск",
    "google_drive", "google drive", "gdrive", "google_disk", "google disk",
    "посилання_на_папку", "папка_гугл", "папка_google",
    "folder_url", "folder_link", "drive_folder_url", "drive_folder", "folder_id",
    "google_drive_folder", "gdrive_folder", "drive_folder_id", "drive_id", "folder",
  ];

  const folderUrl = String(getByKeys_(found.obj, folderAliases) || "").trim();
  const richFolderUrl = extractFolderUrlFromRichText_(branchesSheet, found.rowIndex, found.headerIndexMap, folderAliases);

  const fallbackCell = extractFolderCellByHeaderGuess_(branchesSheet, found.rowIndex, found.headerIndexMap);
  const guessedFolderUrl = extractDriveFolderId_(fallbackCell) ? fallbackCell : "";

  const folderId = extractDriveFolderId_(folderUrl) || extractDriveFolderId_(richFolderUrl) || extractDriveFolderId_(guessedFolderUrl);
  if (!folderId) {
    return {
      ok: false,
      status: "folder_link_missing",
      reason: "Folder link not found in branch row",
      debug: {
        row_index: found.rowIndex,
        folder_url_raw: folderUrl,
        folder_url_rich_text: richFolderUrl,
        folder_url_guessed: guessedFolderUrl,
      },
    };
  }

  try {
    const folder = DriveApp.getFolderById(folderId);
    return { ok: true, folder, status: "resolved", folder_id: folderId };
  } catch (err) {
    logError_("resolveBranchDriveFolder: DriveApp.getFolderById failed", err);
    const scopeIssue = getDriveScopeIssue_(err);
    return {
      ok: false,
      status: scopeIssue ? "drive_scope_missing" : "folder_access_error",
      reason: String(err || ""),
      folder_id: folderId,
      action_required: scopeIssue
        ? "Run processPendingAnswerPhotos_ from script owner account (or install a time trigger for it) so uploads execute with owner Drive permissions."
        : "Check folder access rights and shared permissions for script account.",
    };
  }
}

function resolveDirectDriveFolder_(payload) {
  const fromPayload = [
    payload?.drive_folder_id,
    payload?.drive_folder_url,
    payload?.folder_id,
    payload?.folder_url,
  ];

  const props = PropertiesService.getScriptProperties();
  const fromProps = [
    props.getProperty("DRIVE_UPLOAD_FOLDER_ID"),
    props.getProperty("DEFAULT_DRIVE_FOLDER_ID"),
    props.getProperty("DRIVE_FOLDER_ID"),
    props.getProperty("DRIVE_UPLOAD_FOLDER_URL"),
  ];

  const source = [...fromPayload, ...fromProps]
    .map(v => String(v || "").trim())
    .find(Boolean);

  if (!source) return null;

  const folderId = extractDriveFolderId_(source);
  if (!folderId) {
    return {
      ok: false,
      status: "direct_folder_invalid",
      reason: "Direct Drive folder value is set, but folder id is invalid",
      raw: source,
    };
  }

  try {
    const folder = DriveApp.getFolderById(folderId);
    return { ok: true, folder, status: "resolved_direct", folder_id: folderId };
  } catch (err) {
    logError_("resolveDirectDriveFolder: DriveApp.getFolderById failed", err);
    const scopeIssue = getDriveScopeIssue_(err);
    return {
      ok: false,
      status: scopeIssue ? "drive_scope_missing" : "direct_folder_access_error",
      reason: String(err || ""),
      folder_id: folderId,
      action_required: scopeIssue
        ? "Run processPendingAnswerPhotos_ from script owner account (or install a time trigger for it) so uploads execute with owner Drive permissions."
        : "Check folder access rights and shared permissions for script account.",
    };
  }
}

function getDriveScopeIssue_(err) {
  const text = String(err && (err.message || err.stack) ? (err.message || err.stack) : err || "");
  if (!text) return false;
  return /DriveApp\.getFolderById/i.test(text)
    && /(auth\/drive|auth\/drive\.readonly|нет разрешения|permission)/i.test(text);
}

function findBranchRowData_(branchesSheet, payload) {
  const range = branchesSheet.getDataRange();
  const values = range.getValues();
  if (!values || values.length < 2) return null;

  const headers = values[0].map(h => String(h || "").trim());
  const normalizedHeaders = headers.map(normalizeHeaderKey_);
  const headerIndexMap = {};
  normalizedHeaders.forEach((h, idx) => {
    if (!h) return;
    if (headerIndexMap[h] === undefined) headerIndexMap[h] = idx;
  });

  const branchId = String(payload?.branch_id || "").trim();
  const branchName = String(payload?.branch_name || "").trim();

  const branchIdKeys = ["branch_id", "id", "branchid", "код", "код_филиала", "код_адреса"];
  const branchNameKeys = ["branch_name", "address", "addr", "name", "title", "адрес", "название", "филиал", "точка"];

  for (let i = 1; i < values.length; i += 1) {
    const row = values[i] || [];
    if (!row.some(cell => String(cell || "").trim() !== "")) continue;

    const obj = {};
    headers.forEach((h, idx) => {
      obj[h] = row[idx];
    });

    const rowBranchId = String(getByKeys_(obj, branchIdKeys) || "").trim();
    if (branchId && rowBranchId === branchId) {
      return { obj, rowIndex: i + 1, headerIndexMap };
    }
  }

  if (branchName) {
    const target = normalizeTextKey_(branchName);
    for (let i = 1; i < values.length; i += 1) {
      const row = values[i] || [];
      if (!row.some(cell => String(cell || "").trim() !== "")) continue;

      const obj = {};
      headers.forEach((h, idx) => {
        obj[h] = row[idx];
      });

      const label = String(getByKeys_(obj, branchNameKeys) || "").trim();
      if (label && normalizeTextKey_(label) === target) {
        return { obj, rowIndex: i + 1, headerIndexMap };
      }
    }
  }

  return null;
}

function extractFolderUrlFromRichText_(sheet, rowIndex, headerIndexMap, folderKeys) {
  if (!sheet || !rowIndex || !headerIndexMap) return "";
  const idx = findHeaderIndexByAliases_(headerIndexMap, folderKeys);
  if (idx < 0) return "";

  try {
    const richText = sheet.getRange(rowIndex, idx + 1).getRichTextValue();
    if (!richText) return "";

    const directLink = richText.getLinkUrl();
    if (directLink) return String(directLink).trim();

    const runs = richText.getRuns ? richText.getRuns() : [];
    for (let i = 0; i < (runs || []).length; i += 1) {
      const run = runs[i];
      const runLink = run?.getLinkUrl ? run.getLinkUrl() : "";
      if (runLink) return String(runLink).trim();
    }
  } catch (_) {}

  return "";
}


function extractFolderCellByHeaderGuess_(sheet, rowIndex, headerIndexMap) {
  if (!sheet || !rowIndex || !headerIndexMap) return "";
  const keys = Object.keys(headerIndexMap || {});
  for (let i = 0; i < keys.length; i += 1) {
    const key = keys[i];
    if (!/(папк|folder|drive|диск)/i.test(key)) continue;
    const idx = headerIndexMap[key];
    if (idx === undefined || idx < 0) continue;
    const value = sheet.getRange(rowIndex, idx + 1).getDisplayValue();
    if (value && extractDriveFolderId_(value)) return String(value).trim();

    const rich = extractFolderUrlFromRichText_(sheet, rowIndex, headerIndexMap, [key]);
    if (rich && extractDriveFolderId_(rich)) return String(rich).trim();
  }
  return "";
}

function findHeaderIndexByAliases_(headerIndexMap, aliases) {
  const list = Array.isArray(aliases) ? aliases : [];
  for (let i = 0; i < list.length; i += 1) {
    const key = normalizeHeaderKey_(list[i]);
    if (!key) continue;
    if (headerIndexMap[key] !== undefined) return headerIndexMap[key];
  }
  return -1;
}

function logInfo_(msg, data) {
  const text = `[INFO] ${msg}${data !== undefined ? ` | ${json_(data)}` : ""}`;
  try {
    Logger.log(text);
  } catch (_) {}
  appendLogRow_("INFO", msg, data !== undefined ? data : "");
}

function logError_(msg, err) {
  const text = err && err.stack ? String(err.stack) : String(err || "");
  try {
    Logger.log(`[ERROR] ${msg}${text ? ` | ${text}` : ""}`);
  } catch (_) {}
  appendLogRow_("ERROR", msg, text);
}

function appendLogRow_(level, message, data) {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sh = getOrCreateSheet_(ss, SHEET_NAMES.logs, LOG_HEADERS);
    sh.appendRow([
      Utilities.formatDate(new Date(), "Europe/Moscow", "yyyy-MM-dd HH:mm:ss"),
      String(level || ""),
      String(message || ""),
      typeof data === "string" ? data : json_(data),
    ]);
  } catch (_) {}
}

function getByKeys_(obj, keys) {
  const map = {};
  Object.keys(obj || {}).forEach(k => {
    map[normalizeHeaderKey_(k)] = obj[k];
  });
  for (let i = 0; i < (keys || []).length; i += 1) {
    const key = normalizeHeaderKey_(keys[i]);
    if (map[key] !== undefined && map[key] !== null && String(map[key]).trim() !== "") {
      return map[key];
    }
  }
  return "";
}

function normalizeTextKey_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/ё/g, "е")
    .replace(/\s+/g, " ")
    .trim();
}

function extractDriveFolderId_(url) {
  const raw = String(url || "").trim();
  if (!raw) return "";

  const m1 = raw.match(/\/folders\/([a-zA-Z0-9_-]+)/);
  if (m1 && m1[1]) return m1[1];

  const m2 = raw.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (m2 && m2[1]) return m2[1];

  if (/^[a-zA-Z0-9_-]{10,}$/.test(raw)) return raw;
  return "";
}

function ensureChildFolderByName_(parentFolder, name) {
  const cleanName = sanitizeDriveName_(name || "Проверка");
  const existing = parentFolder.getFoldersByName(cleanName);
  if (existing.hasNext()) return existing.next();
  return parentFolder.createFolder(cleanName);
}

function findExistingFileUrlByName_(folder, fileName) {
  if (!folder || !fileName) return "";
  try {
    const files = folder.getFilesByName(String(fileName));
    if (files.hasNext()) return files.next().getUrl();
  } catch (_) {}
  return "";
}

function sanitizeDriveName_(value) {
  const cleaned = String(value || "")
    .replace(/[\\/:*?"<>|]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
  return cleaned || "Без названия";
}

function formatDateFolderNameMsk_(date) {
  return Utilities.formatDate(date || new Date(), "Europe/Moscow", "yyyy-MM-dd");
}

function isDataUrlImage_(value) {
  return /^data:image\//i.test(String(value || ""));
}

function decodeImageDataUrl_(dataUrl) {
  const m = String(dataUrl || "").match(/^data:(image\/[a-zA-Z0-9.+-]+);base64,(.+)$/i);
  if (!m) return null;
  const mimeType = m[1].toLowerCase();
  const base64 = m[2] || "";
  if (!base64) return null;
  return {
    mimeType,
    bytes: Utilities.base64Decode(base64),
  };
}

function mimeToFileExt_(mimeType) {
  const mime = String(mimeType || "").toLowerCase();
  if (mime === "image/jpeg" || mime === "image/jpg") return "jpg";
  if (mime === "image/png") return "png";
  if (mime === "image/webp") return "webp";
  if (mime === "image/gif") return "gif";
  return "bin";
}

function buildUploadedPhotoName_(payload, row, rowIdx, photoIdx, ext, bytes) {
  const sid = sanitizeDriveName_(payload?.submission_id || "submission");
  const qid = sanitizeDriveName_(row?.question_id || `q_${rowIdx + 1}`);
  const section = sanitizeDriveName_(row?.section_code || row?.section_id || "section");
  const hash = bytes ? shortSha256Hex_(bytes) : `photo_${photoIdx + 1}`;
  return `${sid}_${section}_${qid}_${hash}.${ext || "bin"}`;
}

function shortSha256Hex_(bytes) {
  const digest = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, bytes);
  return digest
    .map(b => {
      const v = b < 0 ? b + 256 : b;
      return ("0" + v.toString(16)).slice(-2);
    })
    .join("")
    .slice(0, 16);
}

function extractTelegramUserId_(payload, initData) {
  const direct = safe_(payload?.tg_user_id || payload?.tg_id || payload?.tg?.user_id || payload?.tg?.id || "");
  if (direct !== null && direct !== undefined && String(direct).trim() !== "") return direct;

  if (!initData) return "";
  try {
    const parsed = parseInitData_(initData);
    const userRaw = parsed?.user;
    if (!userRaw) return "";
    const user = JSON.parse(userRaw);
    return user?.id || "";
  } catch (err) {
    return "";
  }
}

function sendTelegramMessageFromPayload_(ss, payload, { action } = {}) {
  if (!TELEGRAM_BOT_TOKEN) {
    return { ok: false, info: "bot_token_missing" };
  }

  const initData = safe_(payload?.init_data || payload?.initData || "");
  const tgUser = verifyInitData_(initData, TELEGRAM_BOT_TOKEN);
  let chatId = tgUser?.id || "";
  let infoHint = "";
  if (!chatId) {
    const fallbackId = extractTelegramUserId_(payload, initData);
    if (fallbackId) {
      chatId = fallbackId;
      infoHint = "init_data_invalid_fallback";
    } else {
      return { ok: false, info: tgUser ? "tg_user_id_missing" : "init_data_invalid" };
    }
  }

  const text = buildTelegramMessageText_(payload, { action });
  if (!text) {
    return { ok: false, info: "message_text_empty" };
  }

  const sendRes = sendTelegramMessage_(chatId, text);
  if (sendRes.ok && infoHint) {
    return { ...sendRes, info: infoHint };
  }
  return sendRes;
}

function buildTelegramMessageText_(payload, { action } = {}) {
  const direct = safe_(payload?.message_text || payload?.text || "");
  if (direct) return String(direct);

  const zoneRaw = String(payload?.zone || "").toLowerCase();
  const zoneText = (
    zoneRaw === "green" ? "зелёную зону" :
    zoneRaw === "yellow" ? "жёлтую зону" :
    zoneRaw === "red" ? "красную зону" :
    zoneRaw ? "серую зону" : ""
  );
  const link = safe_(payload?.result_link || payload?.link || "");
  const linkText = link ? String(link) : "";

  let text = zoneText
    ? `Проверка завершена. Вы прошли на ${zoneText}.`
    : "Проверка завершена.";
  if (linkText) text += ` Ссылка на проверку: ${linkText}`;
  if (!text && action) text = `Проверка завершена (${action}).`;
  return text;
}

function sendTelegramMessage_(chatId, text) {
  const url = `https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`;
  const payload = {
    chat_id: chatId,
    text: String(text || ""),
    parse_mode: "HTML",
    disable_web_page_preview: false,
  };

  try {
    const resp = UrlFetchApp.fetch(url, {
      method: "post",
      contentType: "application/json",
      payload: JSON.stringify(payload),
      muteHttpExceptions: true,
    });
    const status = resp.getResponseCode();
    const body = resp.getContentText();
    const ok = status >= 200 && status < 300;
    return { ok, info: ok ? "sent" : `status_${status}`, response: body };
  } catch (err) {
    return { ok: false, info: String(err) };
  }
}

function verifyInitData_(initData, botToken) {
  if (!initData || !botToken) return null;

  const data = parseInitData_(initData);
  if (!data || !data.hash) return null;

  const checkString = buildDataCheckString_(data);
  const secretKey = Utilities.computeHmacSha256Signature("WebAppData", botToken);
  const checkBytes = Utilities.newBlob(checkString).getBytes();
  const hash = Utilities.computeHmacSha256Signature(checkBytes, secretKey);
  const hex = bytesToHex_(hash);

  if (hex !== String(data.hash).toLowerCase()) return null;

  try {
    return data.user ? JSON.parse(data.user) : null;
  } catch (_) {
    return null;
  }
}

function verifyTelegramLogin_(loginData, botToken) {
  if (!botToken || !loginData || !loginData.hash) return null;
  const checkString = buildDataCheckString_(loginData);
  const secret = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, botToken);
  const hash = Utilities.computeHmacSha256Signature(checkString, secret);
  const hex = bytesToHex_(hash);
  if (hex !== String(loginData.hash).toLowerCase()) return null;
  return loginData;
}

function parseInitData_(initData) {
  const out = {};
  String(initData || "").split("&").forEach(pair => {
    const idx = pair.indexOf("=");
    const key = idx >= 0 ? pair.slice(0, idx) : pair;
    const val = idx >= 0 ? pair.slice(idx + 1) : "";
    if (!key) return;
    out[decodeURIComponent(key)] = decodeURIComponent(String(val || "").replace(/\+/g, " "));
  });
  return out;
}

function buildDataCheckString_(data) {
  const keys = Object.keys(data || {}).filter(k => k !== "hash").sort();
  return keys.map(key => `${key}=${data[key]}`).join("\n");
}

function bytesToHex_(bytes) {
  return (bytes || [])
    .map(b => {
      const v = b < 0 ? b + 256 : b;
      return ("0" + v.toString(16)).slice(-2);
    })
    .join("");
}

function escapeHtml_(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

/***************
 * Submission fetch helpers (for shareable result links)
 ***************/
function getMySubmissionsPayload_(ss, tgUserId, limitRaw) {
  const id = String(safe_(tgUserId)).trim();
  if (!id) return { ok: false, error: "No tg_user_id", items: [] };

  const sh = ss.getSheetByName(SHEET_NAMES.submissions);
  if (!sh) return { ok: true, tg_user_id: id, items: [], total: 0 };

  const values = sh.getDataRange().getValues();
  if (values.length < 2) return { ok: true, tg_user_id: id, items: [], total: 0 };

  const headers = values[0].map(h => String(h).trim());
  const normalizedHeaders = headers.map(normalizeHeaderKey_);
  const normalizedMap = {};
  normalizedHeaders.forEach((h, i) => { if (h) normalizedMap[h] = i; });

  const idCol = normalizedMap.tg_user_id ?? headers.indexOf("tg_user_id");
  if (idCol < 0) return { ok: false, error: "tg_user_id column missing", items: [] };

  const parsedLimit = Number.parseInt(String(limitRaw || ""), 10);
  const limit = Number.isFinite(parsedLimit) && parsedLimit > 0 ? parsedLimit : MY_SUBMISSIONS_DEFAULT_LIMIT;

  const items = [];
  let total = 0;

  for (let i = values.length - 1; i >= 1; i -= 1) {
    const rowId = String(safe_(values[i][idCol])).trim();
    if (!rowId || rowId !== id) continue;
    total += 1;
    if (items.length >= limit) continue;
    const obj = {};
    headers.forEach((h, j) => {
      const value = values[i][j];
      const normKey = normalizedHeaders[j];
      if (h) obj[h] = value;
      if (normKey && obj[normKey] === undefined) obj[normKey] = value;
    });
    items.push(obj);
  }

  return {
    ok: true,
    tg_user_id: id,
    total,
    items,
    meta: { updatedAt: new Date().toISOString() }
  };
}

function getSubmissionPayload_(ss, submissionId) {
  if (!submissionId) return { ok: false, error: "No submission_id" };

  const sub = findRowById_(ss.getSheetByName(SHEET_NAMES.submissions), "submission_id", submissionId);
  if (!sub) return { ok: false, error: "Submission not found", submission_id: submissionId };

  const answers = findRowsById_(ss.getSheetByName(SHEET_NAMES.answers), "submission_id", submissionId);
  const answersNormalized = normalizeAnswersRows_(answers);
  const issues = buildIssuesFromAnswerRows_(answersNormalized);
  const meta = parseJsonObject_(sub.meta_json);
  const savedPayload = meta?.saved_payload && typeof meta.saved_payload === "object" ? meta.saved_payload : null;

  return {
    ok: true,
    submission_id: submissionId,
    submission: sub,
    payload: savedPayload,
    answers,
    answers_normalized: answersNormalized,
    issues,
    meta: { updatedAt: new Date().toISOString() }
  };
}

function normalizeAnswersRows_(rows) {
  return (rows || []).map(normalizeAnswerRow_);
}

function normalizeAnswerRow_(row) {
  const scoreEarned = toNumberOrEmpty_(row?.score_earned);
  const scoreMax = toNumberOrEmpty_(row?.score_max);
  const hasScores = scoreEarned !== "" && scoreMax !== "";
  const maxPositive = hasScores && Number(scoreMax) > 0;
  const isIssue = maxPositive ? Number(scoreEarned) < Number(scoreMax) : false;

  return {
    ...row,
    score_earned: scoreEarned,
    score_max: scoreMax,
    photos: parsePhotosJson_(row?.photos_json),
    is_issue: isIssue,
  };
}

function toNumberOrEmpty_(value) {
  if (value === "" || value === null || value === undefined) return "";
  const num = Number(String(value).replace(",", "."));
  return Number.isFinite(num) ? num : "";
}

function parsePhotosJson_(value) {
  const raw = safe_(value);
  if (!raw) return [];
  try {
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) return parsed.map(safe_).filter(Boolean);
  } catch (_) {}
  return [raw];
}

function buildIssuesFromAnswerRows_(rows) {
  const issues = [];
  (rows || []).forEach(row => {
    if (!row?.is_issue) return;
    issues.push({
      qid: safe_(row.question_id),
      title: safe_(row.question_text),
      sectionTitle: safe_(row.section_title),
      severity: safe_(row.severity) || "noncritical",
      score: row.score_earned,
      score_earned: row.score_earned,
      score_max: row.score_max,
      comment: safe_(row.comment),
      photos: row.photos || [],
    });
  });
  return issues;
}

function findRowById_(sh, idHeader, idValue) {
  if (!sh) return null;
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return null;

  const headers = values[0].map(h => String(h).trim());
  const idCol = headers.indexOf(idHeader);
  if (idCol < 0) return null;

  for (let i = 1; i < values.length; i++) {
    if (String(values[i][idCol] || "").trim() === idValue) {
      const obj = {};
      headers.forEach((h, j) => obj[h] = values[i][j]);
      return obj;
    }
  }
  return null;
}

function findRowsById_(sh, idHeader, idValue) {
  if (!sh) return [];
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return [];

  const headers = values[0].map(h => String(h).trim());
  const idCol = headers.indexOf(idHeader);
  if (idCol < 0) return [];

  const out = [];
  for (let i = 1; i < values.length; i++) {
    if (String(values[i][idCol] || "").trim() === idValue) {
      const obj = {};
      headers.forEach((h, j) => obj[h] = values[i][j]);
      out.push(obj);
    }
  }
  return out;
}

function getHeaderMap_(sh) {
  const lastCol = sh.getLastColumn();
  if (lastCol === 0) return {};
  const headers = sh.getRange(1, 1, 1, lastCol).getValues()[0]
    .map(h => String(h || "").trim());
  const map = {};
  headers.forEach((h, i) => { if (h) map[h] = i + 1; }); // 1-based
  return map;
}

function appendObjectRowByHeaders_(sh, obj) {
  const map = getHeaderMap_(sh);
  const lastCol = sh.getLastColumn();
  const row = new Array(lastCol).fill("");

  Object.keys(obj || {}).forEach(key => {
    const col = map[key];
    if (col) row[col - 1] = obj[key];
  });

  sh.appendRow(row);
}

function updateObjectRowByHeaders_(sh, rowIndex, obj) {
  if (!sh || !rowIndex) return;
  const map = getHeaderMap_(sh);
  Object.keys(obj || {}).forEach(key => {
    const col = map[key];
    if (!col) return;
    const value = obj[key];
    if (value === undefined || value === null) return;
    sh.getRange(rowIndex, col).setValue(value);
  });
}

function getObjectRowByIndex_(sh, rowIndex) {
  if (!sh || !rowIndex) return {};
  const lastCol = sh.getLastColumn();
  if (!lastCol) return {};
  const headers = sh.getRange(1, 1, 1, lastCol).getValues()[0].map(h => String(h || "").trim());
  const values = sh.getRange(rowIndex, 1, 1, lastCol).getValues()[0];
  const obj = {};
  headers.forEach((h, i) => { if (h) obj[h] = values[i]; });
  return obj;
}

function findSheetRowIndexByValue_(sh, header, value) {
  if (!sh || !header) return 0;
  const target = String(value || "").trim();
  if (!target) return 0;
  const map = getHeaderMap_(sh);
  const col = map[header];
  if (!col) return 0;
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return 0;
  const values = sh.getRange(2, col, lastRow - 1, 1).getValues();
  for (let i = 0; i < values.length; i += 1) {
    if (String(values[i][0] || "").trim() === target) return i + 2;
  }
  return 0;
}

function appendObjectsRowsByHeaders_(sh, objects) {
  if (!objects || !objects.length) return;

  const map = getHeaderMap_(sh);
  const lastCol = sh.getLastColumn();

  const rows = objects.map(obj => {
    const row = new Array(lastCol).fill("");
    Object.keys(obj || {}).forEach(key => {
      const col = map[key];
      if (col) row[col - 1] = obj[key];
    });
    return row;
  });

  sh.getRange(sh.getLastRow() + 1, 1, rows.length, lastCol).setValues(rows);
}

function upsertInspector_(ss, payload) {
  const sh = getOrCreateSheet_(ss, SHEET_NAMES.inspectors, INSPECTORS_HEADERS);

  const tg = payload.tg || {};
  const tgUserId = safe_(payload.tg_user_id || payload.tg_id || tg.user_id || tg.id);
  const fio = safe_(payload.fio || payload.tg_name || tg.name || "");

  if (!tgUserId && !fio) return;

  const now = new Date().toISOString();
  const headerMap = getHeaderMap_(sh);

  const idCol = headerMap["tg_user_id"];
  const fioCol = headerMap["fio"];

  const lastRow = sh.getLastRow();
  let foundRow = 0;

  if (lastRow >= 2 && idCol && tgUserId) {
    const ids = sh.getRange(2, idCol, lastRow - 1, 1).getValues();
    for (let i = 0; i < ids.length; i++) {
      if (String(ids[i][0] || "").trim() === String(tgUserId).trim()) {
        foundRow = i + 2;
        break;
      }
    }
  }

  if (!foundRow && lastRow >= 2 && fioCol && fio) {
    const targetFio = normalizeFioForCompare_(fio);
    const fios = sh.getRange(2, fioCol, lastRow - 1, 1).getValues();
    for (let i = 0; i < fios.length; i++) {
      if (normalizeFioForCompare_(fios[i][0]) === targetFio) {
        foundRow = i + 2;
        break;
      }
    }
  }

  const record = {
    tg_user_id: tgUserId,
    fio: fio,
    tg_username: safe_(payload.tg_username || tg.username),
    tg_first_name: safe_(payload.tg_first_name || tg.first_name),
    tg_last_name: safe_(payload.tg_last_name || tg.last_name),
    tg_name: safe_(payload.tg_name || tg.name || [tg.first_name, tg.last_name].filter(Boolean).join(" ").trim()),
    updated_at: now,
  };

  if (!foundRow) {
    appendObjectRowByHeaders_(sh, record);
    return;
  }

  Object.keys(record).forEach(key => {
    const col = headerMap[key];
    if (!col) return;

    const nextVal = record[key];
    if (nextVal === "" || nextVal === null || nextVal === undefined) return;

    sh.getRange(foundRow, col).setValue(nextVal);
  });

  if (headerMap.updated_at) {
    sh.getRange(foundRow, headerMap.updated_at).setValue(now);
  }
}
